# =============================================================================
# Vase Agent — environment variables (copy to .env and fill in)
# =============================================================================
# Do not commit a .env file that contains real API keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Third-party APIs
# -----------------------------------------------------------------------------
MODELSCOPE_ACCESS_TOKEN=

JINA_API_KEY=

SERP_IMG_SEARCH_KEY=
# SERP_TEXT_SEARCH_KEY=

# -----------------------------------------------------------------------------
# Alibaba Cloud (optional, used by some tool chains)
# -----------------------------------------------------------------------------
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible, for agent_run and scripts)
# -----------------------------------------------------------------------------
# LLM_BACKEND: vllm (local vLLM, etc.) | modelscope (cloud)
LLM_BACKEND=vllm

# Default model name (vllm; also fallback when MODELSCOPE_MODEL is unset)
LLM_MODEL=Qwen3-VL-8B-Instruct

# --- vllm: custom base_url, or compose from VLLM_HOST + VLLM_PORT ---
LLM_BASE_URL=http://127.0.0.1:8001/v1
# VLLM_HOST=127.0.0.1
# VLLM_PORT=8001
LLM_API_KEY=EMPTY

# --- modelscope ---
# MODELSCOPE_MODEL=Qwen/Qwen3.5-35B-A3B
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# -----------------------------------------------------------------------------
# Agent tool protocol (agent_run)
# -----------------------------------------------------------------------------
# openai = native Chat Completions tools / tool_calls
# xml    = model emits <tool_call>…</tool_call> when function calling is unavailable
VASE_TOOL_MODE=xml

# -----------------------------------------------------------------------------
# Evaluation (metrics/llm_judge, LLM-as-judge)
# -----------------------------------------------------------------------------
# Falls back to the LLM settings above. Aliases: EVAL_LLM_MODEL, EVAL_LLM_BASE_URL, EVAL_LLM_API_KEY
# EVAL_JUDGE_MODEL=Qwen/Qwen3.5-35B-A3B
# EVAL_JUDGE_BASE_URL=https://api-inference.modelscope.cn/v1
# EVAL_JUDGE_API_KEY=

# -----------------------------------------------------------------------------
# Local Museum KB (kb_text_search)
# -----------------------------------------------------------------------------
LOCAL_KB_INDEX_DIR=retriever_runs/structured_full

# -----------------------------------------------------------------------------
# Visit web extraction (tools/visit_extract.py, Playwright)
# -----------------------------------------------------------------------------
# VASE_VISIT_GOTO_TIMEOUT_MS=60000
# VASE_VISIT_POST_LOAD_SLEEP_SEC=2
# VASE_VISIT_WAIT_UNTIL=networkidle
VASE_VISIT_GOTO_TIMEOUT_MS=1000
VASE_VISIT_POST_LOAD_SLEEP_SEC=0.5
VASE_VISIT_WAIT_UNTIL=load
